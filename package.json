{
  "name": "tailwind-stash",
  "displayName": "Tailwind Stash",
  "description": "Collapse Tailwind CSS class strings with bi-directional editor panel",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "beumerr",
  "repository": {
    "type": "git",
    "url": "https://github.com/beumerr/tailwind-stash"
  },
  "bugs": {
    "url": "https://github.com/beumerr/tailwind-stash/issues"
  },
  "homepage": "https://github.com/beumerr/tailwind-stash#readme",
  "icon": "docs/icon.png",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/github/actions/workflow/status/beumerr/tailwind-stash/ci.yml?branch=master&label=CI",
      "href": "https://github.com/beumerr/tailwind-stash/actions/workflows/ci.yml",
      "description": "CI Status"
    },
    {
      "url": "https://img.shields.io/github/license/beumerr/tailwind-stash",
      "href": "https://github.com/beumerr/tailwind-stash/blob/master/LICENSE",
      "description": "License"
    }
  ],
  "engines": {
    "vscode": "^1.66.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
    "tailwind",
    "tailwindcss",
    "css",
    "collapse",
    "fold",
    "class",
    "clsx",
    "cva",
    "jsx",
    "react"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tailwindStash.collapseAll",
        "title": "Tailwind Stash: Collapse All Classnames"
      },
      {
        "command": "tailwindStash.expandAll",
        "title": "Tailwind Stash: Expand All Classnames"
      },
      {
        "command": "tailwindStash.toggleCollapse",
        "title": "Tailwind Stash: Toggle Collapse Classnames"
      },
      {
        "command": "tailwindStash.showCssPreview",
        "title": "Tailwind Stash: Show Class Editor Panel"
      },
      {
        "command": "tailwindStash.hideCssPreview",
        "title": "Tailwind Stash: Hide Class Editor Panel"
      },
      {
        "command": "tailwindStash.toggleCssPreview",
        "title": "Tailwind Stash: Toggle Class Editor Panel"
      }
    ],
    "configuration": [
      {
        "title": "Folding",
        "properties": {
          "tailwindStash.foldByDefault": {
            "type": "boolean",
            "default": true,
            "description": "Collapse Tailwind classes by default when a file is opened"
          },
          "tailwindStash.placeholderStyle": {
            "type": "string",
            "enum": [
              "count",
              "empty",
              "count-long"
            ],
            "enumDescriptions": [
              "Show just the number (e.g. \"3\")",
              "Show only an ellipsis (…)",
              "Show count with label (e.g. \"3 classes\")"
            ],
            "default": "count",
            "description": "Style of the collapse placeholder"
          },
          "tailwindStash.minClassCount": {
            "type": "number",
            "default": 4,
            "minimum": 1,
            "description": "Minimum number of classes required before collapsing kicks in"
          },
          "tailwindStash.extraLanguages": {
            "type": "array",
            "default": [],
            "description": "(Experimental) Additional language IDs to enable collapsing for, beyond the built-in set (html, jsx, tsx, vue, svelte, astro, php). Requires reload."
          },
          "tailwindStash.supportedFunctions": {
            "type": "array",
            "default": [
              "cn",
              "clsx",
              "cva",
              "cx",
              "twMerge",
              "twJoin",
              "classNames",
              "classnames"
            ],
            "description": "Function names that wrap Tailwind classes. Wrap entries in / delimiters for regex (e.g. \"/^get.*Classes$/\")"
          }
        }
      },
      {
        "title": "Panel",
        "properties": {
          "tailwindStash.scrollEditorOnPanelSelect": {
            "type": "boolean",
            "default": true,
            "description": "Scroll the editor to the class range when clicking a textarea in the panel"
          },
          "tailwindStash.scrollPanelOnEditorSelect": {
            "type": "boolean",
            "default": true,
            "description": "Scroll the panel to the active card when focusing a class in the editor"
          }
        }
      },
      {
        "title": "Appearance",
        "properties": {
          "tailwindStash.elementTextColor": {
            "type": "string",
            "default": "",
            "description": "Color of the element name in the card header (e.g. \"#ee9d28\"). Leave empty to use the default."
          },
          "tailwindStash.activeBorderColor": {
            "type": "string",
            "default": "",
            "description": "Border color of the active card (e.g. \"#007fd4\"). Leave empty to use the VS Code focus border color."
          },
          "tailwindStash.textareaFocusBackground": {
            "type": "string",
            "default": "",
            "description": "Background color of the textarea when focused (e.g. \"rgba(0,100,200,0.1)\"). Leave empty to use the default selection background."
          },
          "tailwindStash.foldedTextColor": {
            "type": "string",
            "default": "",
            "description": "Color of the collapse placeholder text (e.g. \"#888\", \"rgb(150,150,150)\"). Leave empty to use the default editor code lens color."
          }
        }
      },
      {
        "title": "Keyboard Shortcuts",
        "properties": {
          "tailwindStash.shortcutToggleCollapse": {
            "type": "string",
            "default": "alt+shift+t",
            "description": "Keyboard shortcut for Toggle Collapse. Requires reload."
          },
          "tailwindStash.shortcutCollapseAll": {
            "type": "string",
            "default": "alt+shift+c",
            "description": "Keyboard shortcut for Collapse All. Requires reload."
          },
          "tailwindStash.shortcutExpandAll": {
            "type": "string",
            "default": "alt+shift+e",
            "description": "Keyboard shortcut for Expand All. Requires reload."
          },
          "tailwindStash.shortcutShowPanel": {
            "type": "string",
            "default": "alt+shift+p",
            "description": "Keyboard shortcut for Show Class Editor Panel. Requires reload."
          },
          "tailwindStash.shortcutHidePanel": {
            "type": "string",
            "default": "",
            "description": "Keyboard shortcut for Hide Class Editor Panel. Requires reload."
          },
          "tailwindStash.shortcutTogglePanel": {
            "type": "string",
            "default": "alt+shift+l",
            "description": "Keyboard shortcut for Toggle Class Editor Panel. Requires reload."
          }
        }
      }
    ],
    "keybindings": [
      {
        "command": "tailwindStash.toggleCollapse",
        "key": "alt+shift+t",
        "when": "editorTextFocus"
      },
      {
        "command": "tailwindStash.collapseAll",
        "key": "alt+shift+c",
        "when": "editorTextFocus"
      },
      {
        "command": "tailwindStash.expandAll",
        "key": "alt+shift+e",
        "when": "editorTextFocus"
      },
      {
        "command": "tailwindStash.showCssPreview",
        "key": "alt+shift+p",
        "when": "editorTextFocus"
      },
      {
        "command": "tailwindStash.toggleCssPreview",
        "key": "alt+shift+l",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run compile",
    "compile": "tsc -p ./ && tsx esbuild.webview.mts",
    "compile:webview": "tsx esbuild.webview.mts",
    "watch": "tsc -watch -p ./ & tsx esbuild.webview.mts --watch",
    "lint": "oxlint -c oxlint.config.mjs && tsx scripts/lint-component-structure.mts",
    "format": "oxfmt --write src/ test/ vitest.config.ts esbuild.webview.mts oxlint.config.mjs scripts/",
    "format:check": "oxfmt --check src/ test/ vitest.config.ts esbuild.webview.mts oxlint.config.mjs scripts/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage && npm run test:vscode",
    "test:unit": "vitest run --coverage",
    "pretest:vscode": "tsc -p test/vscode-e2e/tsconfig.json",
    "test:vscode": "tsx scripts/run-vscode-tests.mts",
    "package": "npx @vscode/vsce package --out dist/",
    "release": "tsx scripts/publish.mts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@testing-library/preact": "^3.2.4",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.19.37",
    "@types/vscode": "~1.66.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "glob": "^13.0.6",
    "happy-dom": "^20.8.3",
    "mocha": "^11.0.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "preact": "^10.28.4",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
